<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RegisterFragment">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@drawable/gradient_background"
        android:textColor="#FFFFFF">

        <TextView
            android:id="@+id/titleText1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48sp"
            android:text="CyberTrack Geofencing Client "
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pairedToOrg"
            android:layout_width="336dp"
            android:layout_height="75dp"
            android:layout_marginBottom="32dp"
            android:text="Device registered to: "
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pairedAsName"
            android:layout_width="335dp"
            android:layout_height="75dp"
            android:layout_marginBottom="32dp"
            android:text="Device paired as: "
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bottomInfo"
            android:layout_width="wrap_content"
            android:layout_height="75dp"
            android:layout_marginBottom="32dp"
            android:text="Contact organisation administrator to change device name or to release it from tracking."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />


    </LinearLayout>

</FrameLayout>